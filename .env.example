# Copy to .env and fill in. The pipeline loads .env automatically (real
# environment variables always win over this file). .env is gitignored.

# Storage backend for the whole pipeline: s3 (default) or local.
#   s3    → the shared bucket (real source of truth)
#   local → a local mirror under ./local_store/ with the same key layout,
#           so a fully local run chains stage→stage with no network
# Override per run with the --local / --s3 flags.
STORAGE_BACKEND=s3

# --- S3 backend (required when STORAGE_BACKEND=s3) ---
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=eu-central-1
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com   # only for R2/B2/MinIO
# S3_PREFIX=data/raw            # default key prefix
# S3_DELETE_LOCAL=0             # 1/true/yes → delete the working file after a save

# --- local backend (optional) ---
# LOCAL_STORE=./local_store     # where the local mirror lives

# --- scrapers ---
ENTSOE_API_KEY=your-entsoe-token
